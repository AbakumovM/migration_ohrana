# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Секретный ключ для подписи сессий (любая случайная строка, минимум 32 символа)
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа

# Учётные данные для входа
AUTH_USERNAME=mikhail

# Хэш пароля SHA-256. Сгенерировать:
# python3 -c "import hashlib; print(hashlib.sha256('ВАШ_ПАРОЛЬ'.encode()).hexdigest())"
AUTH_PASSWORD_HASH=
